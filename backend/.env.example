# EduChain backend environment example.
# Normally you do not need to copy this file by hand:
# scripts/deploy.py generates backend/.env after contracts are deployed.

GANACHE_URL=http://127.0.0.1:8545
CHAIN_ID=1337
FLASK_DEBUG=1
SECRET_KEY=educhain-dev-secret-key-change-in-prod

# Filled by scripts/deploy.py
EDU_TOKEN_ADDRESS=
MATERIAL_REGISTRY_ADDRESS=
DOWNLOAD_LOG_ADDRESS=
DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=

# Filled by scripts/deploy.py for Ganache accounts 1-9
ACCOUNT_1_ADDRESS=
ACCOUNT_1_PRIVATE_KEY=
